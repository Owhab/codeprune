{
  "name": "codeprune",
  "version": "1.0.3",
  "description": "A fast, reliable CLI tool to detect and clean up unused files and imports in your JS/TS projects",
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "bin": {
    "codeprune": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "release": "release-it"
  },
  "keywords": [
    "unused-files",
    "dead-code",
    "clean-up",
    "typescript",
    "javascript",
    "esbuild",
    "cli"
  ],
  "author": "Abdul Owhab <mail.owhab@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Owhab/codeprune.git"
  },
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "release-it": "^20.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
